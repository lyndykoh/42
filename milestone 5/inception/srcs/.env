# ---------------------------------------------------------
# DOMAIN SETUP
# ---------------------------------------------------------
# Your domain name must point to your local IP address[cite: 64]. 
# It must be login.42.fr[cite: 65].
DOMAIN_NAME=lkoh.42.fr

# ---------------------------------------------------------
# MARIADB SETUP
# ---------------------------------------------------------
# Variables needed to initialize the database and create users.
SQL_DATABASE=wordpress
SQL_USER=lkoh_user
# Strong passwords should be used here. Make sure this file is ignored by Git! 
SQL_PASSWORD=a_very_secure_db_password
SQL_ROOT_PASSWORD=a_very_secure_root_password

# ---------------------------------------------------------
# WORDPRESS SETUP
# ---------------------------------------------------------
