WP_TITLE=Inception_Lyndy

# Admin user details
WP_ADMIN_USER=lyndy_boss
WP_ADMIN_PASSWORD=a_very_secure_wp_admin_password
WP_ADMIN_EMAIL=lyndy@student.42.fr

# Second regular user details
